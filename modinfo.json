    "effect": [
	{"math": [ "KS_P_STP_DEX", "=", "KS_STP_DEX()"]},
	{"math": [ "KS_P_STP_INT", "=", "KS_STP_INT()"]},
	{"math": [ "KS_P_STP_PER", "=", "KS_STP_PER()"]},
	{"math": [ "KS_P_STP_STR", "=", "KS_STP_STR()"]},
	 {
      "if": {
  "and": [
    { "u_has_profession": "prof_knives_familiar" },
	{ "u_has_profession": "prof_knives_familiar" }

  ]
},
	 "then": [{"math": [ "prof_knives_familiar", "=", "1"]},{"math": [ "prof_knives_familiar", "=", "1"]}],
      "else": { "u_message": "Canceled" }
    }
	] 
  },
  {
    "type": "mutation",
    "id": "stats_through_proficiencies",
    "name": { "str": "U cant see this" },
    "description": "If u see this, then this bug.",
    "points": 1,
    "enchantments": [ { "values": 
	[ 
	{ "value": "DEXTERITY", "add": "KS_STP_DEX()" },
	{ "value": "INTELLIGENCE", "add": "KS_STP_INT()" },
	{ "value": "PERCEPTION", "add": "KS_STP_PER()" },
	{ "value": "STRENGTH", "add": "KS_STP_STR()" } 
	] } ]
  },
